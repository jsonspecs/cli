{
  "name": "jsonspecs-cli",
  "version": "2.0.0",
  "private": true,
  "description": "CLI backend and local studio host for jsonspecs rules projects",
  "type": "commonjs",
  "bin": {
    "jsonspecs": "bin/jsonspecs.js"
  },
  "main": "index.js",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:pack": "node scripts/pack-smoke.js",
    "verify": "npm test && npm run test:pack",
    "pack:release": "node scripts/create-release-package.js",
    "prepublishOnly": "node scripts/prevent-direct-publish.js"
  },
  "config": {
    "jsonspecsVersion": "2.0.0",
    "jsonspecsGitRef": "v2.0.0"
  },
  "dependencies": {
    "express": "^5.2.1",
    "jsonspecs": "file:../jsonspecs"
  },
  "repository": { "type": "git", "url": "git+https://github.com/catindev/jsonspecs-cli.git" },
  "bugs": { "url": "https://github.com/catindev/jsonspecs-cli/issues" },
  "homepage": "https://github.com/catindev/jsonspecs-cli#readme",
  "keywords": ["jsonspecs", "validation", "rules-engine", "cli"],
  "files": ["bin", "lib", "static", "index.js", "README.md", "LICENSE", "CHANGELOG.md"]
}
