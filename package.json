{
  "name": "jsonspecs-cli",
  "version": "4.0.1",
  "private": true,
  "description": "Authoring, validation, snapshot build, sample-test, and local sandbox CLI for jsonspecs projects",
  "type": "commonjs",
  "bin": {
    "jsonspecs": "bin/jsonspecs.js"
  },
  "main": "index.js",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:pack": "node scripts/pack-smoke.js",
    "verify": "npm test && npm run test:pack",
    "pack:release": "node scripts/create-release-package.js",
    "prepublishOnly": "node scripts/prevent-direct-publish.js"
  },
  "config": {
    "rulesVersion": "4.0.0",
    "rulesGitRef": "v4.0.0"
  },
  "dependencies": {
    "@jsonspecs/rules": "file:../rules",
    "express": "^5.2.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsonspecs/cli.git"
  },
  "bugs": {
    "url": "https://github.com/jsonspecs/cli/issues"
  },
  "homepage": "https://github.com/jsonspecs/cli#readme",
  "keywords": [
    "jsonspecs",
    "validation",
    "rules-engine",
    "cli"
  ],
  "files": [
    "bin",
    "lib",
    "static",
    "index.js",
    "README.md",
    "TESTING.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
